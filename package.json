{
  "name": "@hamdymohamedak/openfetch",
  "version": "1.0.0",
  "description": "OpenFetch is a lean, TypeScript-first HTTP client on the native Fetch API—middleware and interceptors instead of a monolithic core, with plug-in retries, timeouts, lifecycle hooks, and structured debug logging. Optional in-memory caching, fluent chaining via the sugar export, and small utilities for safer URLs, idempotency keys, and redacted logs (headers and query strings) keep requests observable without leaking secrets. ESM-only, zero runtime dependencies, tree-shakeable exports; runs on Node 18+, browsers, Bun, Deno, and edge runtimes (e.g. Cloudflare Workers), with a design that plays well with Server Components",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./sugar": {
      "types": "./dist/sugar/fluent.d.ts",
      "import": "./dist/sugar/fluent.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs",
    "security-tests"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test:security": "npm run build && node security-tests/run.mjs",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "fetch",
    "http",
    "http-client",
    "https",
    "rest",
    "rest-client",
    "api-client",
    "middleware",
    "interceptors",
    "retry",
    "timeout",
    "cache",
    "typescript",
    "esm",
    "rsc",
    "react-server-components",
    "nextjs",
    "nodejs",
    "bun",
    "deno",
    "cloudflare-workers",
    "edge",
    "browser",
    "isomorphic",
    "universal",
    "zero-dependencies",
    "fluent",
    "abortcontroller",
    "axios-alternative",
    "ky-alternative",
    "openfetch"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openfetch-js/OpenFetch.git"
  },
  "homepage": "https://openfetch-js.github.io/openfetch-docs/",
  "bugs": {
    "url": "https://github.com/openfetch-js/OpenFetch/issues"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
